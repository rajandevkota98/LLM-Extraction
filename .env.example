# Copy to .env and fill in. Everything here is optional: with no API key the
# pipeline runs on the deterministic mock adapter, so a clean checkout always works.

# --- OpenRouter (default when a key is present) ------------------------------
# https://openrouter.ai/keys
# Left commented on purpose: a placeholder value here is a non-empty key, which
# would select OpenRouter over any other provider and fail every call with a 401.
# OPENROUTER_API=sk-or-...

# Model slug. OpenRouter ids are always "provider/model", sometimes with a
# published variant suffix such as ":free". Browse exact slugs at
# https://openrouter.ai/models -- a bare name without the provider prefix is
# rejected at startup.
MODEL="openai/gpt-oss-120b"

# Optional provider routing: throughput, price, or latency. This replaces the
# retired ":nitro" and ":floor" model suffixes. Unset means OpenRouter's default.
# OPENROUTER_SORT=throughput

# Optional. Override only if you are proxying OpenRouter.
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional attribution headers. These put your app on the OpenRouter
# leaderboards; they have no effect on extraction.
# OPENROUTER_SITE_URL=https://example.com
# OPENROUTER_APP_NAME=quote-extraction

# --- Anthropic (used when ANTHROPIC_API_KEY is set and OPENROUTER_API is not) -
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8

# --- Provider selection ------------------------------------------------------
# "mock", "openrouter", or "anthropic". Leave unset to auto-detect from whichever
# key is present, falling back to "mock". `python main.py --mock` always wins.
# LLM_PROVIDER=
