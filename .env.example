# Copy to .env and fill in. Everything here is optional: with no API key the
# pipeline runs on the deterministic mock adapter, so a clean checkout always works.

# --- OpenRouter (default when a key is present) ------------------------------
# https://openrouter.ai/keys
OPENROUTER_API="Your api key"

# Model slug. OpenRouter ids are always "provider/model", optionally with a
# routing variant suffix like ":nitro" (throughput) or ":floor" (price).
# Browse exact slugs at https://openrouter.ai/models -- a bare name without the
# provider prefix will be rejected at startup.
MODEL="openai/gpt-oss-120b:nitro"

# Optional. Override only if you are proxying OpenRouter.
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional attribution headers. These put your app on the OpenRouter
# leaderboards; they have no effect on extraction.
# OPENROUTER_SITE_URL=https://example.com
# OPENROUTER_APP_NAME=quote-extraction

# --- Anthropic (used when ANTHROPIC_API_KEY is set and OPENROUTER_API is not) -
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8

# --- Provider selection ------------------------------------------------------
# "mock", "openrouter", or "anthropic". Leave unset to auto-detect from whichever
# key is present, falling back to "mock". `python main.py --mock` always wins.
# LLM_PROVIDER=
